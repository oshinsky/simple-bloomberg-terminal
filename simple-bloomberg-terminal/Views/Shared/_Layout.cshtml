<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] — BBT</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/simple_bloomberg_terminal.styles.css" asp-append-version="true"/>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
<body>
<header id="main-nav" data-turbo-permanent>
    <nav class="navbar navbar-expand-sm">
        <div class="container-fluid" style="max-width:1200px; margin:0 auto; padding:0 1rem;">
            <a class="terminal-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <span class="brand-bracket">[</span>BBT<span class="brand-bracket">]</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                <ul class="navbar-nav" style="gap:0.25rem;">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Terminal</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Countries" asp-action="Index">Countries</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Companies" asp-action="Index">Companies</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Events" asp-action="Index">Events</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    <div class="ticker-bar">
        <div class="ticker-inner">
            <span>SPX <span class="up">▲ 5,421.03 +0.42%</span></span>
            <span>NDX <span class="up">▲ 19,082.54 +0.61%</span></span>
            <span>DJI <span class="down">▼ 39,118.86 −0.11%</span></span>
            <span>BTC <span class="up">▲ 64,220.00 +1.87%</span></span>
            <span>EURUSD <span class="down">▼ 1.0841 −0.05%</span></span>
            <span>WTI <span class="up">▲ 79.34 +0.73%</span></span>
            <span>GOLD <span class="up">▲ 2,341.10 +0.29%</span></span>
            <span>VIX <span class="down">▼ 13.82 −2.14%</span></span>
            <span>10Y UST 4.38%</span>
            <span>SPX <span class="up">▲ 5,421.03 +0.42%</span></span>
            <span>NDX <span class="up">▲ 19,082.54 +0.61%</span></span>
            <span>DJI <span class="down">▼ 39,118.86 −0.11%</span></span>
            <span>BTC <span class="up">▲ 64,220.00 +1.87%</span></span>
            <span>EURUSD <span class="down">▼ 1.0841 −0.05%</span></span>
            <span>WTI <span class="up">▲ 79.34 +0.73%</span></span>
            <span>GOLD <span class="up">▲ 2,341.10 +0.29%</span></span>
            <span>VIX <span class="down">▼ 13.82 −2.14%</span></span>
            <span>10Y UST 4.38%</span>
        </div>
    </div>
</header>

<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer id="main-footer" data-turbo-permanent class="terminal-footer">
    <div class="container">
        <div class="footer-inner">
            <div>
                &copy; 2026 &mdash; <span style="color:var(--accent);">Bloomberg Terminal</span>
                &nbsp;&middot;&nbsp;
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
            <div class="footer-status">
                <span class="footer-dot"></span>
                FEED ACTIVE
            </div>
        </div>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
<script>
(function () {
  function setActiveNav() {
    document.querySelectorAll('.navbar-nav .nav-link').forEach(function (link) {
      link.classList.toggle('active', new URL(link.href).pathname === location.pathname);
    });
  }

  function runScripts(container) {
    // innerHTML does NOT execute scripts — clone each script node and re-append it
    container.querySelectorAll('script').forEach(function (oldScript) {
      var s = document.createElement('script');
      if (oldScript.src) {
        s.src = oldScript.src;
      } else {
        s.textContent = oldScript.textContent;
      }
      Array.from(oldScript.attributes).forEach(function (attr) {
        if (attr.name !== 'src') s.setAttribute(attr.name, attr.value);
      });
      oldScript.parentNode.replaceChild(s, oldScript);
    });
  }

  function swapPage(url) {
    fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function (r) { return r.text(); })
      .then(function (html) {
        var doc = new DOMParser().parseFromString(html, 'text/html');
        var newMain = doc.querySelector('main');
        if (!newMain) return;
        var el = document.querySelector('main');
        el.innerHTML = newMain.innerHTML;
        runScripts(el);           // re-execute any scripts in the new content
        document.title = doc.title;
        history.pushState(null, doc.title, url);
        window.scrollTo(0, 0);
        setActiveNav();
      })
      .catch(function () { location.href = url; }); // fallback: normal nav
  }

  document.addEventListener('click', function (e) {
    var link = e.target.closest('a[href]');
    if (!link) return;
    var url;
    try { url = new URL(link.href); } catch (err) { return; }
    if (url.origin !== location.origin) return;
    if (link.target === '_blank') return;
    if (link.hasAttribute('data-bs-toggle')) return; // bootstrap modals etc
    e.preventDefault();
    swapPage(url.href);
  });

  window.addEventListener('popstate', function () {
    swapPage(location.href);
  });

  setActiveNav();
})();
</script>
</body>
</html>
